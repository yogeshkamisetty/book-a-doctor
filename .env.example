# Copy to .env and fill in real values (never commit .env).

MONGO_URI=mongodb://127.0.0.1:27017/book-a-doctor
# Or MongoDB Atlas:
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/book-a-doctor?retryWrites=true&w=majority

JWT_SECRET=change-this-to-a-long-random-string

PORT=5000

# Comma-separated origins for CORS (Next.js default dev port is 3000)
FRONTEND_ORIGIN=http://localhost:3000
